#!/bin/sh
# Luna CLI — version, status, help, welcome, tui

set -eu

LUNA_SHARE="${LUNA_SHARE:-/usr/share/luna}"

if [ -r "$LUNA_SHARE/luna-apk-repo.sh" ]; then
	# shellcheck disable=SC1091
	. "$LUNA_SHARE/luna-apk-repo.sh"
fi

load_release() {
	if [ -r /etc/luna-release ]; then
		# shellcheck disable=SC1091
		. /etc/luna-release
	fi
}

_luna_installed_ver() {
	if ver="$(luna_base_pkg_version 2>/dev/null)" && [ -n "$ver" ]; then
		printf '%s' "$ver"
		return 0
	fi
	load_release
	printf '%s' "${LUNA_VERSION:-unknown}"
}

cmd_version() {
	ver="$(_luna_installed_ver)"
	load_release
	printf 'Luna %s\n' "$ver"
	printf '  phase:  %s\n' "${LUNA_PHASE:-?}"
	printf '  base:   %s\n' "${LUNA_BASE:-Alpine}"
	printf '  kernel: %s\n' "$(uname -r)"
	printf '  arch:   %s\n' "$(uname -m)"
}

_net_line() {
	ip -4 -o addr show scope global 2>/dev/null | awk '
		{ printf "  %s  %s\n", $2, $4 }
	' | head -5
}

_persist_state() {
	if grep -q '[[:space:]]/mnt/persist[[:space:]]' /proc/mounts 2>/dev/null; then
		df -h /mnt/persist 2>/dev/null | awk 'NR==2 { printf "mounted (%s free on %s)\n", $4, $1 }'
	else
		if blkid -L LUNA_DATA >/dev/null 2>&1; then
			echo "LUNA_DATA found, not mounted"
		else
			echo "not configured"
		fi
	fi
}

_agent_state() {
	if rc-service luna-agent status 2>/dev/null | grep -q started; then
		echo "running (stub)"
	else
		echo "stopped (stub)"
	fi
}

_boot_mode() {
	if [ -f /etc/luna-release ]; then
		# shellcheck disable=SC1091
		. /etc/luna-release
		if [ "${LUNA_MODE:-}" = "installed" ]; then
			echo "installed (disk)"
			return
		fi
	fi
	local fstype
	fstype="$(findmnt -no FSTYPE / 2>/dev/null || true)"
	case "$fstype" in
		tmpfs|overlay|aufs) echo "live (ISO)" ;;
		*) echo "installed (disk)" ;;
	esac
}

cmd_status() {
	load_release
	hostname="$(hostname 2>/dev/null || echo luna)"
	uptime_s="$(cut -d. -f1 /proc/uptime 2>/dev/null || echo 0)"
	uptime_h=$(( uptime_s / 3600 ))
	uptime_m=$(( (uptime_s % 3600) / 60 ))

	printf '🌙 Luna %s · %s · %dh %dm\n' "$(_luna_installed_ver)" "$hostname" "$uptime_h" "$uptime_m"
	printf '  boot:     %s\n' "$(_boot_mode)"
	printf '  memory:   '
	free -h 2>/dev/null | awk '/^Mem:/ { print $3 " used / " $2 " total" }' || echo "n/a"
	printf '  network:\n'
	if _net_line | grep -q .; then
		_net_line
	else
		printf '  (no global IPv4 yet)\n'
	fi
	printf '  persist:  %s\n' "$(_persist_state)"
	printf '  agent:    %s\n' "$(_agent_state)"
	printf '  sshd:     '
	if rc-service sshd status 2>/dev/null | grep -q started; then
		echo "running"
	else
		echo "stopped"
	fi
	if command -v apk >/dev/null 2>&1; then
		printf '  packages: %s installed\n' "$(apk info -I 2>/dev/null | wc -l | tr -d ' ')"
	fi
}

cmd_welcome() {
	if [ -x "$LUNA_SHARE/welcome-screen.sh" ]; then
		exec "$LUNA_SHARE/welcome-screen.sh"
	fi
	cmd_help
}

cmd_think() {
	secs="${1:-5}"
	if [ -x "$LUNA_SHARE/thinking.sh" ]; then
		exec "$LUNA_SHARE/thinking.sh" "$secs"
	fi
	echo "thinking.sh not found" >&2
	exit 1
}

cmd_help() {
	load_release
	cat <<EOF
Luna ${LUNA_VERSION:-?} — Luna Shell

Usage: luna [command]

Commands:
  (none)          welcome screen (Luna Shell)
  version, -v     show Luna version
  status          system overview (network, persist, services)
  think [sec]     moon phase animation (agent preview, default 5s)
  install         install Luna to disk (live ISO only, root)
  upgrade         update Luna release + Alpine packages (root, network)
  self-update     update Luna CLI/scripts from GitHub only (root)
  help, -h        this message
  tui             simple interactive menu

Legacy: luna-help (same as luna help)

Agent stub: rc-service luna-agent start|stop|status
SSH (NAT):  ssh -p 2222 luna@127.0.0.1
EOF
}

cmd_install() {
	if [ "$(id -u)" -ne 0 ]; then
		echo "luna install requires root — run: sudo luna install" >&2
		exit 1
	fi
	if ! command -v bash >/dev/null 2>&1; then
		echo "luna install requires bash" >&2
		exit 1
	fi
	exec bash "$LUNA_SHARE/luna-install.sh"
}

_alpine_repo_ver() {
	# shellcheck disable=SC1091
	. /etc/os-release 2>/dev/null || VERSION_ID=3.20
	# %.* — minor release (3.20); %%.* ошибочно даёт только major (3)
	printf '%s' "${VERSION_ID%.*}"
}

_ensure_cdn_repos() {
	local ver luna_line
	ver="$(_alpine_repo_ver)"

	luna_line=""
	if [ -f /etc/apk/repositories ]; then
		luna_line="$(grep '^/var/lib/luna/apk-repo$' /etc/apk/repositories 2>/dev/null | head -1 || true)"
	fi

	if [ -f /etc/apk/repositories ] && grep -q 'dl-cdn.alpinelinux.org' /etc/apk/repositories; then
		if ! grep -q '^http:' /etc/apk/repositories 2>/dev/null && \
			grep -q "alpine/v${ver}/" /etc/apk/repositories 2>/dev/null; then
			if command -v luna_apk_repo_present >/dev/null 2>&1 && \
				luna_apk_repo_present && \
				! grep -qxF "/var/lib/luna/apk-repo" /etc/apk/repositories 2>/dev/null; then
				ensure_luna_apk_repo_in_repositories
			fi
			return 0
		fi
	fi

	cat > /etc/apk/repositories <<EOF
https://dl-cdn.alpinelinux.org/alpine/v${ver}/main
https://dl-cdn.alpinelinux.org/alpine/v${ver}/community
EOF
	if command -v luna_apk_repo_present >/dev/null 2>&1 && luna_apk_repo_present; then
		ensure_luna_apk_repo_in_repositories
	elif [ -n "$luna_line" ]; then
		printf '%s\n' "$luna_line" >> /etc/apk/repositories
	fi
	printf '  apk repos:     switched to CDN Alpine v%s\n' "$ver"
}

cmd_self_update() {
	if [ "$(id -u)" -ne 0 ]; then
		echo "luna self-update requires root — run: sudo luna self-update" >&2
		exit 1
	fi
	if ! command -v bash >/dev/null 2>&1; then
		echo "luna self-update requires bash" >&2
		exit 1
	fi
	if [ ! -x "$LUNA_SHARE/luna-self-update.sh" ]; then
		echo "luna self-update: script not found" >&2
		exit 1
	fi
	exec bash "$LUNA_SHARE/luna-self-update.sh"
}

cmd_upgrade() {
	if [ "$(id -u)" -ne 0 ]; then
		echo "luna upgrade requires root — run: sudo luna upgrade" >&2
		exit 1
	fi
	if ! command -v apk >/dev/null 2>&1; then
		echo "luna upgrade: apk not found" >&2
		exit 1
	fi

	ver_before="$(_luna_installed_ver)"
	boot="$(_boot_mode)"
	kernel_before="$(uname -r)"

	printf '🌙 Luna upgrade\n\n'
	printf '  Luna release:  %s\n' "$ver_before"
	printf '  boot:          %s\n' "$boot"
	printf '  kernel:        %s\n\n' "$kernel_before"

	if [ "$boot" = "live (ISO)" ]; then
		printf 'Note: live ISO — updates are lost after reboot.\n'
		printf '      Install to disk: sudo luna install\n\n'
	fi

	_ensure_cdn_repos

	if command -v bash >/dev/null 2>&1 && [ -x "$LUNA_SHARE/luna-self-update.sh" ]; then
		bash "$LUNA_SHARE/luna-self-update.sh" || true
	fi

	if command -v luna_apk_repo_present >/dev/null 2>&1 && luna_apk_repo_present; then
		ensure_luna_apk_repo_in_repositories
	fi

	printf 'Updating Alpine package index...\n'
	apk update || exit 1

	printf 'Upgrading Alpine packages...\n'
	apk upgrade || exit 1

	ver_after="$(_luna_installed_ver)"
	kernel_after="$(uname -r)"
	pkg_count="$(apk info -I 2>/dev/null | wc -l | tr -d ' ')"

	printf '\n🌙 Upgrade complete\n'
	printf '  Luna release:  %s' "$ver_before"
	if [ "$ver_before" != "$ver_after" ]; then
		printf ' → %s' "$ver_after"
	fi
	printf '\n'
	printf '  packages:      %s installed\n' "$pkg_count"
	if [ "$kernel_before" != "$kernel_after" ]; then
		printf '  kernel:        %s → %s (reboot recommended)\n' "$kernel_before" "$kernel_after"
	elif apk info -e linux-virt linux-lts 2>/dev/null | grep -q .; then
		printf '  tip:           reboot if kernel packages were upgraded\n'
	fi
}

cmd_tui() {
	if ! command -v bash >/dev/null 2>&1; then
		echo "luna tui requires bash" >&2
		exit 1
	fi
	exec bash "$LUNA_SHARE/luna-tui.sh"
}

main() {
	case "${1:-}" in
		version|-v|--version) cmd_version ;;
		status)               cmd_status ;;
		help|-h|--help)       cmd_help ;;
		think)                cmd_think "${2:-5}" ;;
		install)              cmd_install ;;
		upgrade)              cmd_upgrade ;;
		self-update)          cmd_self_update ;;
		tui|menu)             cmd_tui ;;
		"")                   cmd_welcome ;;
		*)
			printf 'luna: unknown command %s\n\n' "$1" >&2
			cmd_help >&2
			exit 1
			;;
	esac
}

main "$@"
